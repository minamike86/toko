datasource db {
  provider = "mysql" // atau postgresql
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/* ======================================================
   Produk DOMAIN
   ====================================================== */

model Product {
  id        String   @id
  name      String
  brand     String?
  isActive  Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants  ProductVariant[]
}

model ProductVariant {
  id          String   @id
  productId   String
  sku         String   @unique
  variantName String
  unit        String
  sizeLabel   String?
  colorLabel  String?
  basePrice   Int
  isActive    Boolean
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product         Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  inventoryItems  InventoryItem[]
  orderItems      OrderItem[]
  stockMovements  StockMovement[]

  @@index([productId])
}

/* ======================================================
   SALES DOMAIN
   ====================================================== */

model Order {
  id                String   @id
  type              String
  status            String
  totalAmount       Int
  outstandingAmount Int
  createdAt         DateTime
  createdBy         String
  version           Int      @default(0)

  items             OrderItem[]

  payments Payment[] // relasi pasif, tanpa logic
  
  @@index([status])
  @@index([createdAt])
  
}

model OrderItem {
  id                   String @id
  orderId              String

  productId            String
  variantId           String?
  productNameSnapshot  String
  unitSnapshot         String
  unitPriceSnapshot    Int
  quantity             Int
  subtotal             Int

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([variantId])
 
}

/* ======================================================
   INVENTORY DOMAIN
   ====================================================== */

model InventoryItem {  
  variantId String @id
  quantity  Int

  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([quantity])
  
 
}

model StockMovement {
  id          String   @id
  productId   String
  variantId   String?
  type        String   // IN | OUT | ADJUST
  origin      String   // LEGACY | MANUAL_ADJUSTMENT | PURCHASE
  quantity    Int
  reason      String
  referenceId String?
  occurredAt  DateTime

  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Restrict)

  @@index([productId])
  @@index([variantId])
  @@index([referenceId])
  @@index([occurredAt])
}

model Payment {
  id         String   @id @default(cuid())
  orderId    String
  amount     Int
  paidAt     DateTime
  method     String
  createdAt  DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([paidAt])
}

model SystemSetting {
  key        String   @id
  value      String
  updatedAt  DateTime @updatedAt
  updatedBy  String
}
